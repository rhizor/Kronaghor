# Kronaghor Environment Variables
# Copiar a .env y configurar

# ⚠️ IMPORTANTE: En producción, establecer SECRET_KEY
ENV=dev

# Database
DATABASE_URL=sqlite:///./kronaghor.db

# Security
# Generar con: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=
DEBUG=false

# API
API_HOST=0.0.0.0
API_PORT=8000

# CORS - En producción, especificar dominios exactos
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# AI Providers (configurar al menos uno)
# OpenAI
OPENAI_API_KEY=

# Grok (xAI)
GROK_API_KEY=

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_AI_PROVIDER=ollama
